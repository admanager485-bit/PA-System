#!/usr/bin/env python3
import os, time, threading, socket, requests, uuid
from flask import Flask, request, jsonify, render_template_string
from werkzeug.utils import secure_filename
import urllib3

urllib3.disable_warnings()

app = Flask(__name__)
app.config['UPLOAD_FOLDER'] = '/tmp/'
os.makedirs(app.config['UPLOAD_FOLDER'], exist_ok=True)

ACTIVE_RECEIVERS = set()
SCHEDULED_TASKS = []

# --- 1. NETWORK DISCOVERY (Tells Pi where the Mac is) ---
def beacon_broadcaster():
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
    while True:
        try: s.sendto(b"MAC_SENDER_BEACON", ('<broadcast>', 5005))
        except: pass
        time.sleep(3)

# --- 2. TASK SCHEDULER ---
def task_scheduler():
    global SCHEDULED_TASKS
    while True:
        now = time.time()
        for task in SCHEDULED_TASKS[:]:
            if now >= task['execute_at']:
                if task['type'] == 'text': broadcast_text(task['data'])
                elif task['type'] == 'audio': broadcast_audio(task['data'])
                SCHEDULED_TASKS.remove(task)
        time.sleep(1)

threading.Thread(target=beacon_broadcaster, daemon=True).start()
threading.Thread(target=task_scheduler, daemon=True).start()

# --- 3. TRANSMISSION ENGINES ---
def broadcast_text(text):
    if not ACTIVE_RECEIVERS: return
    for ip in list(ACTIVE_RECEIVERS):
        try: requests.post(f"http://{ip}:5000/api/speak", json={"text": text}, timeout=3)
        except: ACTIVE_RECEIVERS.discard(ip)

def broadcast_audio(filepath):
    if not ACTIVE_RECEIVERS: return
    for ip in list(ACTIVE_RECEIVERS):
        try:
            with open(filepath, 'rb') as f:
                files = {'audio_file': (os.path.basename(filepath), f)}
                requests.post(f"http://{ip}:5000/api/play", files=files, timeout=10)
        except: ACTIVE_RECEIVERS.discard(ip)

# --- 4. WEB ENDPOINTS ---
@app.route('/register', methods=['POST'])
def register_node():
    ACTIVE_RECEIVERS.add(request.remote_addr)
    return "OK"

@app.route('/')
def dashboard(): return render_template_string(HTML_UI)

@app.route('/api/status')
def status(): return jsonify({"receivers": len(ACTIVE_RECEIVERS), "tasks": len(SCHEDULED_TASKS)})

@app.route('/api/trigger_text', methods=['POST'])
def trigger_text():
    text = request.form.get('text')
    delay = int(request.form.get('delay', 0))
    if delay > 0: SCHEDULED_TASKS.append({'type': 'text', 'data': text, 'execute_at': time.time() + delay})
    else: threading.Thread(target=broadcast_text, args=(text,)).start()
    return "OK"

@app.route('/api/trigger_audio', methods=['POST'])
def trigger_audio():
    delay = int(request.form.get('delay', 0))
    if 'file' not in request.files: return "No file", 400
    file = request.files['file']
    filepath = os.path.join(app.config['UPLOAD_FOLDER'], f"cmd_{uuid.uuid4().hex}")
    file.save(filepath)
    if delay > 0: SCHEDULED_TASKS.append({'type': 'audio', 'data': filepath, 'execute_at': time.time() + delay})
    else: threading.Thread(target=broadcast_audio, args=(filepath,)).start()
    return "OK"

