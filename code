if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
EOF

sudo chmod +x /usr/local/bin/pa_system.py

# 5. Create SystemD Auto-Start Service for the Python App
echo "⚙️ Configuring Background Service..."
cat << EOF | sudo tee /etc/systemd/system/pa_system.service > /dev/null
[Unit]
Description=All-In-One PA System
After=network.target

[Service]
ExecStart=/usr/bin/python3 /usr/local/bin/pa_system.py
Restart=always
User=root

[Install]
WantedBy=multi-user.target
EOF

sudo systemctl daemon-reload
sudo systemctl enable pa_system.service
sudo systemctl restart pa_system.service

# 6. Configure Chromium Kiosk Mode to Auto-Start on Desktop Boot
