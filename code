#!/bin/bash
echo "================================================"
echo "🌟 INITIATING ALL-IN-ONE PA SYSTEM CONSOLE"
echo "================================================"

# 1. Install System Audio, Video, and Web Tools
echo "📦 Installing System Packages..."
sudo apt-get update && sudo apt-get install espeak alsa-utils python3-pip ffmpeg chromium-browser -y

# 2. Install Python Web Libraries
echo "🐍 Installing Python Dependencies..."
pip3 install flask werkzeug --break-system-packages

# 3. Force Audio out of the 3.5mm Headphone Jack (not HDMI)
echo "🔊 Routing Audio to Headphone Jack..."
sudo amixer cset numid=3 1 > /dev/null 2>&1
sudo raspi-config nonint do_audio 1

# 4. Write the Master Python Web App & Audio Player
echo "🧠 Injecting System Brain..."
cat << 'EOF' | sudo tee /usr/local/bin/pa_system.py > /dev/null
#!/usr/bin/env python3
import os, time, threading, subprocess, uuid
from flask import Flask, request, jsonify, render_template_string
from werkzeug.utils import secure_filename

app = Flask(__name__)
app.config['UPLOAD_FOLDER'] = '/tmp/'
os.makedirs(app.config['UPLOAD_FOLDER'], exist_ok=True)

SCHEDULED_TASKS = []

# --- 1. TASK SCHEDULER ---
def task_scheduler():
    global SCHEDULED_TASKS
    while True:
        now = time.time()
        for task in SCHEDULED_TASKS[:]:
            if now >= task['execute_at']:
                if task['type'] == 'text':
                    play_text(task['data'])
                elif task['type'] == 'audio':
                    play_audio(task['data'])
                SCHEDULED_TASKS.remove(task)
        time.sleep(1)

threading.Thread(target=task_scheduler, daemon=True).start()

# --- 2. LOCAL AUDIO ENGINES (Outputs to Headphone Jack) ---
def play_text(text):
    subprocess.run(["espeak", text])

def play_audio(filepath):
    # Convert any uploaded file (MP3, WebM) to WAV for native Linux playback
    wav_path = f"{filepath}.wav"
    subprocess.run(["ffmpeg", "-y", "-i", filepath, wav_path], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(["aplay", "-q", wav_path])
    try: os.remove(wav_path); os.remove(filepath)
    except: pass

# --- 3. WEB ENDPOINTS ---
@app.route('/')
def dashboard():
    return render_template_string(HTML_UI)

@app.route('/api/status')
def status():
    return jsonify({"tasks": len(SCHEDULED_TASKS)})

@app.route('/api/trigger_text', methods=['POST'])
def trigger_text():
    text = request.form.get('text')
    delay = int(request.form.get('delay', 0))
    if delay > 0:
        SCHEDULED_TASKS.append({'type': 'text', 'data': text, 'execute_at': time.time() + delay})
    else:
        threading.Thread(target=play_text, args=(text,)).start()
    return "OK"

@app.route('/api/trigger_audio', methods=['POST'])
def trigger_audio():
    delay = int(request.form.get('delay', 0))
    if 'file' not in request.files: return "No file", 400
    file = request.files['file']
    filepath = os.path.join(app.config['UPLOAD_FOLDER'], f"cmd_{uuid.uuid4().hex}")
    file.save(filepath)
    if delay > 0:
        SCHEDULED_TASKS.append({'type': 'audio', 'data': filepath, 'execute_at': time.time() + delay})
    else:
        threading.Thread(target=play_audio, args=(filepath,)).start()
    return "OK"

