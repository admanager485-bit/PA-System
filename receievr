#!/bin/bash
echo "================================================"
echo "🔊 INSTALLING PI RECEIVER"
echo "================================================"

# 1. Install Linux Audio Tools and Converters
sudo apt-get update && sudo apt-get install espeak alsa-utils python3-pip ffmpeg -y
pip3 install flask requests werkzeug --break-system-packages

# 2. Force Audio out of the Headphone Jack
sudo amixer cset numid=3 1 > /dev/null 2>&1
sudo raspi-config nonint do_audio 1

# 3. Write the Python Receiver Logic
cat << 'EOF' | sudo tee /usr/local/bin/pi_receiver.py > /dev/null
#!/usr/bin/env python3
import os, socket, threading, subprocess, requests, uuid
from flask import Flask, request

app = Flask(__name__)
os.makedirs("/tmp/pa_audio", exist_ok=True)

# --- FIND THE MAC SENDER ---
def find_mac_and_register():
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.bind(('', 5005))
    while True:
        try:
            data, addr = s.recvfrom(1024)
            if b"MAC_SENDER_BEACON" in data:
                mac_ip = addr[0]
                try: requests.post(f"http://{mac_ip}:8080/register", timeout=2)
                except: pass
        except: pass

threading.Thread(target=find_mac_and_register, daemon=True).start()

# --- RECEIVE & PLAY AUDIO ---
@app.route('/api/speak', methods=['POST'])
def api_speak():
    text = request.json.get('text')
    subprocess.run(["espeak", text])
    return "OK"

@app.route('/api/play', methods=['POST'])
def api_play():
    file = request.files['audio_file']
    raw_path = f"/tmp/pa_audio/{uuid.uuid4().hex}"
    wav_path = f"{raw_path}.wav"
    file.save(raw_path)
    
    # ffmpeg converts the MP3 or WebM from the Mac into a standard Linux WAV file
    subprocess.run(["ffmpeg", "-y", "-i", raw_path, wav_path], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(["aplay", "-q", wav_path]) # Play through headphone jack
    
    try: os.remove(raw_path); os.remove(wav_path)
    except: pass
    return "OK"

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
EOF

sudo chmod +x /usr/local/bin/pi_receiver.py

# 4. Set as Background Service
cat << EOF | sudo tee /etc/systemd/system/pi_receiver.service > /dev/null
[Unit]
Description=PA Receiver Node
After=network.target

[Service]
ExecStart=/usr/bin/python3 /usr/local/bin/pi_receiver.py
Restart=always
User=root

[Install]
WantedBy=multi-user.target
EOF

sudo systemctl daemon-reload
sudo systemctl enable pi_receiver.service
sudo systemctl restart pi_receiver.service

echo "================================================"
echo "✅ PI IS READY AND LISTENING FOR MAC!"
echo "================================================"
